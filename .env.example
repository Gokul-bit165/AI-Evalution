# GPU Inference API Configuration
# Copy this file to .env and configure values

# API Security
API_KEY=your-secure-api-key-min-32-chars-here

# Server Configuration
PORT=3000
HOST=127.0.0.1

# Ollama Configuration
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b

# Request Limits
REQUEST_TIMEOUT_MS=60000
MAX_BODY_SIZE=2mb

# Logging
LOG_LEVEL=info
NODE_ENV=production
